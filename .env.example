# Core paths. Adjust these on the target server after cloning.
WHISPER_ROOT=S:\development\source\local-whisper
WHISPER_INBOX=S:\development\source\local-whisper\inbox
WHISPER_OUT=S:\development\source\local-whisper\out
WHISPER_ARCHIVE=S:\development\source\local-whisper\archive
WHISPER_FAILED=S:\development\source\local-whisper\failed

# Default portable profile. Good quality and safer VRAM use.
WHISPER_MODEL=large-v3
WHISPER_LANGUAGE=ru
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=int8_float16
WHISPER_BEAM_SIZE=5
WHISPER_VAD_FILTER=true
WHISPER_POLL_SECONDS=5
WHISPER_MIN_AUDIO_BYTES=1024

# Optional LM Studio polishing. Start LM Studio local server first.
LM_STUDIO_ENABLED=false
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_MODEL=local-model
LM_STUDIO_PROMPT=Исправь очевидные ошибки распознавания речи, сохрани смысл, имена, числа и структуру. Не добавляй факты.
# REST API. Change the token before exposing the service.
WHISPER_API_HOST=127.0.0.1
WHISPER_API_PORT=8088
WHISPER_API_TOKEN=change-this-token
WHISPER_API_MAX_UPLOAD_BYTES=262144000
