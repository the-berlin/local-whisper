# RTX 4060 8GB profile
WHISPER_ROOT=S:\development\source\whisper
WHISPER_INBOX=S:\development\source\whisper\inbox
WHISPER_OUT=S:\development\source\whisper\out
WHISPER_ARCHIVE=S:\development\source\whisper\archive
WHISPER_FAILED=S:\development\source\whisper\failed

WHISPER_MODEL=large-v3
WHISPER_LANGUAGE=ru
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=int8_float16
WHISPER_BEAM_SIZE=5
WHISPER_VAD_FILTER=true
WHISPER_POLL_SECONDS=5
WHISPER_MIN_AUDIO_BYTES=1024

LM_STUDIO_ENABLED=false
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_MODEL=local-model
LM_STUDIO_PROMPT=Исправь очевидные ошибки распознавания речи, сохрани смысл, имена, числа и структуру. Не добавляй факты.
